rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── User profile doc ────────────────────────────────────────────────
    // Read: only the user themselves. Listing other users requires
    // superadmin which is enforced by the Lambda (admin-list-users).
    //
    // Write: NONE from clients. All writes happen via the Admin SDK from:
    //   - cg-poker record-signin (lastSeen, signInCount, displayName, photoURL,
    //     firstSeen)
    //   - cg-poker admin-set-plan (systemDesign tier)
    //   - sa-auth code-login / confirm-session (premium, tier, activatedAt,
    //     sessionId for system-design)
    //   - sa-webhook (Stripe payment)
    //   - set-superadmin.mjs script (superadmin flag — one allowed email)
    //
    // Closing client writes entirely prevents any frontend manipulation of
    // tier/premium/superadmin — the user cannot self-upgrade by writing
    // Firestore directly, only via Stripe + the webhook.
    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ── Connect-4 leaderboard (unchanged) ──────────────────────────────
    match /connect4Leaderboard/{entryId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['name','mode','steps','moves','difficulty','createdAt','uid'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.name.size() <= 20
        && request.resource.data.mode in ['human-first', 'ai-first']
        && request.resource.data.steps is int
        && request.resource.data.steps >= 7
        && request.resource.data.steps <= 42
        && request.resource.data.moves is list
        && request.resource.data.moves.size() == request.resource.data.steps
        && request.resource.data.difficulty == 'impossible'
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    // ── Poker storage doc (read-own-only, Admin-SDK writes) ────────────
    // Contains the user's poker tier + cumulative storage stats. The user
    // sees their own quota in the bb100 settings drawer; everything else
    // (tier upgrades, Stripe state) is server-managed.
    match /pokerStorage/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Poker session docs (one per upload session) ────────────────────
    match /pokerSessions/{uid}/sessions/{sessionId} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ── Admin dashboard metrics ─────────────────────────────────────────
    // metrics/userCounts holds the cumulative-sign-ups counter the admin
    // dashboard reads. Even superadmins read it through the Lambda (which
    // re-verifies superadmin from users/{uid}.superadmin) so the doc is
    // entirely server-controlled.
    match /metrics/{docId} {
      allow read:  if false;
      allow write: if false;
    }

    // ── AI usage counters (server-only) ─────────────────────────────────
    // sa-chat increments these on each AI call. The frontend reads the
    // returned remaining-quota in the API response — never directly.
    match /aiUsage/{docId} {
      allow read:  if false;
      allow write: if false;
    }

    // ── Ultimate Texas Hold'em tables (read: seated players · write: NONE) ──
    // The public table doc is readable only while your uid is in seatUids
    // (the cg-uth Lambda seats you). Hole cards live in private/{uid},
    // readable by that player alone. private/_dealer holds the undealt deck
    // and the dealer's hole cards — '_dealer' is never a Firebase uid, so the
    // uid==doc-id rule below makes it unreadable by every client. All writes
    // go through the cg-uth Lambda (Admin SDK) — clients cannot touch chips,
    // cards, or phase.
    match /uthTables/{code} {
      allow read:  if request.auth != null && request.auth.uid in resource.data.seatUids;
      allow write: if false;

      match /private/{uid} {
        allow read:  if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ── Poker stats-share metadata (server-only) ────────────────────────
    // cg-poker writes one doc per shared snapshot. The PUBLIC read of a
    // share goes through the Lambda (which fetches the actual payload
    // from R2 and password-gates if needed) — clients NEVER read or write
    // these docs directly. Closing all client access here means even if a
    // malicious client knew a shareId, they couldn't bypass the password
    // gate or revocation flag by talking to Firestore directly.
    match /pokerShares/{shareId} {
      allow read:  if false;
      allow write: if false;
    }
  }
}
